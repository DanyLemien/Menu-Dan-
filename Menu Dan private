  actualiserResumeSelection();
  afficherResultats();
  if (etat.selectionPlats.size) ouvrirSelection(); else fermerFiche();
}

function retirerCoches() {
  const coches = [...elements.contenuModal.querySelectorAll("[data-cocher-retrait]:checked")].map(el => el.dataset.cocherRetrait);
  if (!coches.length) return afficherToast("Aucun plat coché");
  coches.forEach(id => { etat.selectionPlats.delete(id); delete etat.quantitesSelection[id]; delete etat.prixUnitairesSaisis[id]; });
  if (!etat.selectionPlats.size) etat.restaurantSelection = "";
  memoriserSelection();
  actualiserResumeSelection();
  afficherResultats();
  if (etat.selectionPlats.size) ouvrirSelection(); else fermerFiche();
}

function obtenirDonneesCommande() {
  const selection = platsSelectionnes().sort((a, b) => ordreCategorie(a.categorie) - ordreCategorie(b.categorie) || a.indexOriginal - b.indexOriginal);
  const groupes = new Map();
  let total = 0;
  let lignesAControler = 0;
  let articles = 0;
  selection.forEach(plat => {
    const categorie = plat.categorie || "Autres";
    if (!groupes.has(categorie)) groupes.set(categorie, []);
    const quantite = Math.max(1, Number(etat.quantitesSelection[plat.identifiant] || 1));
    const controle = obtenirPrixUnitaire(plat);
    const montant = controle.valide ? quantite * controle.valeur : null;
    if (montant === null) lignesAControler += 1; else total += montant;
    articles += quantite;
    groupes.get(categorie).push({ plat, quantite, controle, montant });
  });
  return { selection, groupes, total, lignesAControler, articles };
}

function ouvrirCommande() {
  const donnees = obtenirDonneesCommande();
  if (!donnees.selection.length) return;
  const groupesHtml = [...donnees.groupes.entries()].map(([categorie, lignes]) => `<section class="commande-groupe">
    <h3>${echapperHtml(categorie)}</h3>

function retirerIdentifiant(id) {
  etat.selectionPlats.delete(id);
  delete etat.quantitesSelection[id];
  delete etat.prixUnitairesSaisis[id];
  if (!etat.selectionPlats.size) etat.restaurantSelection = "";

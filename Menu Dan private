        <button type="button" class="bouton-danger" id="viderSelectionModal">Vider toute la sélection</button>
        <button type="button" class="bouton-commande" id="commandeDepuisSelection">Afficher la commande</button>
        <button type="button" class="bouton-neutre" id="retourDepuisSelection">Retour aux résultats</button>
      </div>

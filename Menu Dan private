      ${groupesHtml}
      <div class="commande-total">${donnees.lignesAControler ? "Total calculable" : "Total indicatif"} : ${donnees.total.toFixed(2).replace(".", ",")} CHF</div>
      ${controleHtml}
      <div class="actions-selection-bas">
        <button type="button" class="bouton-photo" id="creerPhotoCommande">Créer la fiche photo</button>
        <button type="button" class="bouton-danger" id="viderSelectionCommande">Vider toute la sélection</button>
        <button type="button" class="bouton-neutre" id="retourCommandeSelection">Modifier la sélection</button>
        <button type="button" class="bouton-neutre" id="retourCommandeResultats">Retour aux résultats</button>
      </div>
    </section>`;
  elements.modal.classList.remove("cache");
  document.body.style.overflow = "hidden";
}

function decouperTexteCanvas(contexte, texte, largeurMax) {
  const mots = String(texte).split(/\s+/);
  const lignes = [];
  let ligne = "";
  mots.forEach(mot => {
    const test = ligne ? ligne + " " + mot : mot;
    if (contexte.measureText(test).width > largeurMax && ligne) {
      lignes.push(ligne);
      ligne = mot;
    } else ligne = test;
  });
  if (ligne) lignes.push(ligne);
  return lignes;
}

async function creerPhotoCommande() {
  const donnees = obtenirDonneesCommande();
  if (!donnees.selection.length) return;
  const largeur = 1600;
  const marge = 90;
  const largeurTexte = largeur - 2 * marge;
  const canvasMesure = document.createElement("canvas");
  const mesure = canvasMesure.getContext("2d");
  mesure.font = "700 34px Arial";
  let hauteur = 260;
  donnees.groupes.forEach((lignes, categorie) => {
    hauteur += 75;
    lignes.forEach(({plat}) => { hauteur += Math.max(62, decouperTexteCanvas(mesure, plat.plat, largeurTexte - 330).length * 43 + 18); });
  });
  hauteur += 250;
  const canvas = document.createElement("canvas");
  canvas.width = largeur;
  canvas.height = hauteur;
  const ctx = canvas.getContext("2d");
  ctx.fillStyle = "#ffffff";
  ctx.fillRect(0,0,largeur,hauteur);
  ctx.fillStyle = "#12733d";
  ctx.fillRect(0,0,largeur,28);
  ctx.fillStyle = "#18211c";
  ctx.font = "900 56px Arial";
  ctx.fillText(etat.restaurantSelection, marge, 105);
  ctx.font = "500 30px Arial";
  ctx.fillStyle = "#5d6861";
  ctx.fillText(`Commande · ${donnees.articles} article(s)`, marge, 155);
  let y = 220;
  donnees.groupes.forEach((lignes, categorie) => {
    ctx.fillStyle = "#12733d";
    ctx.font = "800 34px Arial";
    ctx.fillText(categorie, marge, y);
    y += 20;
    ctx.strokeStyle = "#d7e1da";
    ctx.lineWidth = 3;
    ctx.beginPath(); ctx.moveTo(marge,y); ctx.lineTo(largeur-marge,y); ctx.stroke();
    y += 48;
    lignes.forEach(({plat, quantite, controle, montant}) => {
      const prixAffiche = controle.valide ? controle.valeur.toFixed(2).replace(".", ",") + " CHF" : (controle.original || "prix non renseigné");
      const formule = `${quantite} × ${plat.plat} à ${prixAffiche} =`;
      const montantAffiche = montant === null ? "À préciser" : montant.toFixed(2).replace(".", ",") + " CHF";
      ctx.font = "700 32px Arial";
      ctx.fillStyle = montant === null ? "#8b4c00" : "#18211c";
      const lignesTexte = decouperTexteCanvas(ctx, formule, largeurTexte - 330);
      lignesTexte.forEach((ligne, i) => ctx.fillText(ligne, marge, y + i*42));
      ctx.textAlign = "right";
      ctx.font = "900 32px Arial";
      ctx.fillText(montantAffiche, largeur-marge, y);
      ctx.textAlign = "left";
      y += Math.max(62, lignesTexte.length*42 + 18);
    });
  });
  y += 18;
  ctx.strokeStyle = "#18211c"; ctx.lineWidth = 4;
  ctx.beginPath(); ctx.moveTo(marge,y); ctx.lineTo(largeur-marge,y); ctx.stroke();
  y += 60;
  ctx.textAlign = "right";
  ctx.fillStyle = "#18211c";
  ctx.font = "900 42px Arial";
  ctx.fillText(`${donnees.lignesAControler ? "Total calculable" : "Total"} : ${donnees.total.toFixed(2).replace(".", ",")} CHF`, largeur-marge, y);
  ctx.textAlign = "left";
  if (donnees.lignesAControler) {
    y += 55;
    ctx.font = "700 26px Arial";
    ctx.fillStyle = "#8b4c00";
    ctx.fillText(`${donnees.lignesAControler} prix à préciser, non inclus dans le total.`, marge, y);
  }
  const blob = await new Promise(resolve => canvas.toBlob(resolve, "image/png", 1));
  if (!blob) return afficherToast("Création de la photo impossible");
  const nom = `Commande_${etat.restaurantSelection.replace(/[^a-z0-9]+/gi,"_")}.png`;
  const fichier = new File([blob], nom, {type:"image/png"});
  try {
    if (navigator.share && navigator.canShare && navigator.canShare({files:[fichier]})) {
      await navigator.share({files:[fichier], title:"Fiche de commande"});
    } else {
      const lien = document.createElement("a");
      lien.href = URL.createObjectURL(blob);
      lien.download = nom;
      document.body.appendChild(lien);
      lien.click();
      lien.remove();
      setTimeout(() => URL.revokeObjectURL(lien.href), 1500);
    }
  } catch (erreur) {
    if (erreur && erreur.name !== "AbortError") afficherToast("Enregistrement de la photo impossible");
  }
}

function lienValide(url) {
  const texte = String(url ?? "").trim();
  if (!texte) return "";
  if (/^https?:\/\//i.test(texte)) return texte;
  return "https://" + texte;
}

function numeroTelephone(telephone) {
  return String(telephone ?? "").replace(/[^+\d]/g, "");
}

function ligneFiche(libelle, valeur, autoriserLien = false) {
  const texte = String(valeur ?? "").trim();
  let contenu = echapperHtml(texte || "Non renseigné");
  if (autoriserLien && texte) {
    contenu = `<a href="${echapperHtml(texte)}" target="_blank" rel="noopener">${echapperHtml(texte)}</a>`;
  }
  return `<div class="ligne-fiche"><span class="libelle">${echapperHtml(libelle)}</span><div class="valeur">${contenu}</div></div>`;
}

function ouvrirFiche(index) {
  const p = etat.plats[index];
  if (!p) return;

  const adresse = [p.rue, [p.npa, p.localite].filter(Boolean).join(" ")].filter(Boolean).join(", ");
  const urlCarte = adresse ? "https://www.google.com/maps/search/?api=1&query=" + encodeURIComponent(p.restaurant + ", " + adresse) : "";
  const urlSite = lienValide(p.site);
  const urlMenu = lienValide(p.lienMenu);
  const tel = numeroTelephone(p.telephone);

  const actions = [];
  if (p.telephone) actions.push(`<button type="button" class="action-lien" data-copie="${echapperHtml(p.telephone)}" data-message="Numéro de téléphone copié">Copier le téléphone</button>`);
  if (p.email) actions.push(`<button type="button" class="action-lien rouge" data-copie="${echapperHtml(p.email)}" data-message="Adresse e-mail copiée">Copier l’e-mail</button>`);
  if (adresse) actions.push(`<button type="button" class="action-lien secondaire" data-copie="${echapperHtml(adresse)}" data-message="Adresse copiée">Copier l’adresse</button>`);
  if (urlSite) actions.push(`<button type="button" class="action-lien rouge" data-copie="${echapperHtml(urlSite)}" data-message="Adresse du site copiée">Copier le site Internet</button>`);
  if (urlMenu) actions.push(`<button type="button" class="action-lien secondaire" data-copie="${echapperHtml(urlMenu)}" data-message="Lien du menu copié">Copier le lien du menu</button>`);

  elements.contenuModal.innerHTML = `
    <section class="bloc plat-selectionne">
      <h3>Plat sélectionné</h3>
      ${ligneFiche("Nom du plat", p.plat)}
      ${ligneFiche("Catégorie", p.categorie)}
      ${ligneFiche("Description", p.description)}
      ${ligneFiche("Prix", formaterPrix(p.prix))}
      ${ligneFiche("Localité", [p.npa, p.localite].filter(Boolean).join(" "))}
      ${ligneFiche("Jours de fermeture", p.fermeture)}
      ${ligneFiche("Date d'introduction", p.dateIntroduction)}
    </section>

    <section class="bloc alerte-fermeture">
      <h3>${echapperHtml(valeurOuNonRenseignee(p.restaurant))}</h3>
      <div class="fiche-grid">
        ${ligneFiche("Adresse", adresse)}
        ${ligneFiche("Téléphone", p.telephone)}
        ${ligneFiche("E-mail", p.email)}
        ${ligneFiche("Jours de fermeture", p.fermeture)}
      </div>
    </section>

    <section class="bloc">
      <h3>Fiche technique du restaurant</h3>
      <div class="fiche-grid">
        ${ligneFiche("Type de cuisine", p.typeCuisine)}
        ${ligneFiche("Terrasse", p.terrasse)}
        ${ligneFiche("Horaires", p.horaires)}
        ${ligneFiche("Date du menu", p.dateMenu)}
        ${ligneFiche("Date d'introduction", p.dateIntroduction)}
        ${ligneFiche("Date de récupération Web", p.dateRecuperation)}
        ${ligneFiche("Fichier source", etat.fichier)}
      </div>
      <div class="provenance">
        <span class="libelle">Provenance des informations</span>
        <div class="valeur">${echapperHtml(nettoyerTexte(p.fourniPar) === "web" ? "Personne du groupe" : valeurOuNonRenseignee(p.fourniPar))}</div>
      </div>
      <button type="button" class="bouton-ajouter-selection ${platEstSelectionne(p) ? "selectionne" : ""}" data-basculer-selection="${index}">${platEstSelectionne(p) ? "✓ Retirer de ma sélection" : "Ajouter ce plat à ma sélection"}</button>
      ${actions.length ? `<div class="note-liens"><strong>Liens protégés :</strong> dans la visionneuse ChatGPT, les ouvertures externes sont bloquées. Les boutons ci-dessous copient les informations sans déclencher le message d’erreur. Vous pouvez ensuite les coller dans Téléphone, Mail, Safari ou Plans.</div><div class="actions">${actions.join("")}</div>` : ""}
      <button type="button" class="bouton-retour-fiche" data-retour-resultats>Retour aux résultats</button>
    </section>`;

  elements.modal.classList.remove("cache");
  document.body.style.overflow = "hidden";
  elements.fermerModal.focus();
}

function afficherToast(message) {
  if (!elements.toastCopie) return;
  elements.toastCopie.textContent = message;
  elements.toastCopie.classList.add("visible");
  clearTimeout(afficherToast.minuterie);
  afficherToast.minuterie = setTimeout(() => elements.toastCopie.classList.remove("visible"), 2200);
}

async function copierTexte(texte, message) {
  try {
    if (navigator.clipboard && window.isSecureContext) {
      await navigator.clipboard.writeText(texte);
    } else {
      const zone = document.createElement("textarea");
      zone.value = texte;
      zone.setAttribute("readonly", "");
      zone.style.position = "fixed";
      zone.style.opacity = "0";
      document.body.appendChild(zone);
      zone.select();
      document.execCommand("copy");
      zone.remove();
    }
    afficherToast(message || "Information copiée");
  } catch (erreur) {
    afficherToast("Copie impossible. Maintenez le texte appuyé pour le copier.");
  }
}

function fermerFiche() {
  elements.modal.classList.add("cache");
  document.body.style.overflow = "";
}

function reinitialiserFiltres() {
  elements.recherche.value = "";
  etat.categoriesSelectionnees.clear();
  etat.localitesSelectionnees.clear();
  etat.restaurantsSelectionnes.clear();
  remplirListeMultiple(
    elements.listeCategories,
    valeursUniques("categorie"),
    etat.categoriesSelectionnees,
    elements.boutonCategories,
    "catégorie",
    "catégories",
    actualiserFiltreRestaurants
  );
  remplirListeMultiple(
    elements.listeLocalites,
    valeursUniques("localite"),
    etat.localitesSelectionnees,
    elements.boutonLocalites,
    "localité",
    "localités",
    actualiserFiltreRestaurants
  );
  actualiserFiltreRestaurants();
  document.querySelectorAll(".multi-liste").forEach(element => element.classList.add("cache"));
  elements.effacerRecherche.classList.add("cache");
  afficherResultats();
  fermerSuggestions();
  elements.recherche.focus();
}

elements.fichierCsv.addEventListener("change", evenement => chargerFichier(evenement.target.files[0]));
elements.boutonChanger.addEventListener("click", () => elements.fichierCsv.click());
elements.recherche.addEventListener("input", () => {
  elements.effacerRecherche.classList.toggle("cache", elements.recherche.value.length === 0);
  afficherResultats();
  afficherSuggestions();
});
elements.effacerRecherche.addEventListener("click", () => {
  elements.recherche.value = "";
  elements.effacerRecherche.classList.add("cache");
  fermerSuggestions();
  afficherResultats();
  elements.recherche.focus();
});
elements.recherche.addEventListener("focus", afficherSuggestions);
elements.recherche.addEventListener("keydown", gererClavierSuggestions);
elements.boutonCategories.addEventListener("click", () => basculerListe(elements.boutonCategories, elements.listeCategories));
elements.boutonLocalites.addEventListener("click", () => basculerListe(elements.boutonLocalites, elements.listeLocalites));
elements.boutonRestaurants.addEventListener("click", () => basculerListe(elements.boutonRestaurants, elements.listeRestaurants));
elements.boutonToutAfficher.addEventListener("click", reinitialiserFiltres);
elements.voirSelection.addEventListener("click", ouvrirSelection);
elements.voirCommande.addEventListener("click", ouvrirCommande);
elements.resultats.addEventListener("click", evenement => {
  const ouvrir = evenement.target.closest("[data-ouvrir-fiche]");
  if (ouvrir) return ouvrirFiche(Number(ouvrir.dataset.ouvrirFiche));
  const plus = evenement.target.closest("[data-augmenter-quantite]");
  if (plus) return modifierQuantite(Number(plus.dataset.augmenterQuantite), 1);
  const moins = evenement.target.closest("[data-diminuer-quantite]");
  if (moins) return modifierQuantite(Number(moins.dataset.diminuerQuantite), -1);
  const selection = evenement.target.closest("[data-basculer-selection]");
  if (selection) basculerSelection(Number(selection.dataset.basculerSelection));
});
elements.fermerModal.addEventListener("click", fermerFiche);
elements.contenuModal.addEventListener("change", evenement => {
  const champPrix = evenement.target.closest("[data-prix-unitaire-id]");
  if (!champPrix) return;
  enregistrerPrixUnitaire(champPrix.dataset.prixUnitaireId, champPrix.value);
});

elements.contenuModal.addEventListener("click", evenement => {
  const copie = evenement.target.closest("[data-copie]");
  if (copie) {
    evenement.preventDefault();
    return copierTexte(copie.dataset.copie || "", copie.dataset.message || "Information copiée");
  }
  const selection = evenement.target.closest("[data-basculer-selection]");
  if (selection) {
    basculerSelection(Number(selection.dataset.basculerSelection));
    return ouvrirFiche(Number(selection.dataset.basculerSelection));
  }
  const plusId = evenement.target.closest("[data-augmenter-id]");
  if (plusId) {
    const plat = etat.plats.find(p => p.identifiant === plusId.dataset.augmenterId);
    if (plat) modifierQuantite(etat.plats.indexOf(plat), 1);
    return ouvrirSelection();
  }
  const moinsId = evenement.target.closest("[data-diminuer-id]");
  if (moinsId) {
    const plat = etat.plats.find(p => p.identifiant === moinsId.dataset.diminuerId);
    if (plat) modifierQuantite(etat.plats.indexOf(plat), -1);
    return etat.selectionPlats.size ? ouvrirSelection() : fermerFiche();
  }
  const retrait = evenement.target.closest("[data-retirer-id]");
  if (retrait) return retirerIdentifiant(retrait.dataset.retirerId);
  if (evenement.target.closest("#retirerCoches")) return retirerCoches();
  if (evenement.target.closest("#viderSelectionModal") || evenement.target.closest("#viderSelectionCommande")) { viderSelection(true); fermerFiche(); return; }
  if (evenement.target.closest("#commandeDepuisSelection")) return ouvrirCommande();
  if (evenement.target.closest("#creerPhotoCommande")) return creerPhotoCommande();
  if (evenement.target.closest("#retourCommandeSelection")) return ouvrirSelection();
  if (evenement.target.closest("#retourDepuisSelection") || evenement.target.closest("#retourCommandeResultats") || evenement.target.closest("[data-retour-resultats]")) return fermerFiche();
});

elements.modal.addEventListener("click", evenement => {
  if (evenement.target === elements.modal) fermerFiche();
});
document.addEventListener("keydown", evenement => {
  if (evenement.key === "Escape" && !elements.modal.classList.contains("cache")) fermerFiche();
});
document.addEventListener("click", evenement => {
  if (!evenement.target.closest(".recherche-zone")) fermerSuggestions();
  if (!evenement.target.closest(".multi-filtre")) {
    document.querySelectorAll(".multi-liste").forEach(element => element.classList.add("cache"));
    document.querySelectorAll(".multi-bouton").forEach(element => element.setAttribute("aria-expanded", "false"));
  }
});

function chargerDepuisMemoire() {
  try {
    const sauvegarde = localStorage.getItem(CLE_MEMOIRE);
    if (!sauvegarde) {
      elements.etatChargement.textContent = "Aucun fichier mémorisé. Choisissez le fichier CSV une première fois.";
      return;
    }
    const donnees = JSON.parse(sauvegarde);
    if (!donnees || !donnees.texte) throw new Error("Sauvegarde vide");
    chargerTexteCsv(donnees.texte, donnees.nom, false);
  } catch (erreur) {
    console.warn(erreur);
    elements.etatChargement.className = "etat erreur";
    elements.etatChargement.textContent = "Le fichier mémorisé n’a pas pu être relu. Sélectionnez de nouveau le CSV.";
  }
}

chargerDepuisMemoire();

</script>
<div id="toastCopie" class="toast-copie" role="status" aria-live="polite"></div>
</body>

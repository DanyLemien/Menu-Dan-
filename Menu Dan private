<script>
"use strict";

const CLE_MEMOIRE = "restaurantsNeuchatelCsvV4";
const CLE_SELECTION = "restaurantsNeuchatelSelectionV42";
const VERSION_APPLICATION = "4.6";
const etat = {
  plats: [],
  fichier: "",
  categoriesSelectionnees: new Set(),
  localitesSelectionnees: new Set(),
  restaurantsSelectionnes: new Set(),
  selectionPlats: new Set(),
  quantitesSelection: {},
  prixUnitairesSaisis: {},
  restaurantSelection: "",
  suggestionActive: -1
};

const elements = {
  fichierCsv: document.getElementById("fichierCsv"),
  zoneChargement: document.getElementById("zoneChargement"),
  etatChargement: document.getElementById("etatChargement"),
  application: document.getElementById("application"),
  nomFichier: document.getElementById("nomFichier"),
  nombrePlats: document.getElementById("nombrePlats"),
  nombreRestaurants: document.getElementById("nombreRestaurants"),
  recherche: document.getElementById("recherche"),
  suggestions: document.getElementById("suggestions"),
  effacerRecherche: document.getElementById("effacerRecherche"),
  boutonCategories: document.getElementById("boutonCategories"),
  listeCategories: document.getElementById("listeCategories"),
  boutonLocalites: document.getElementById("boutonLocalites"),
  listeLocalites: document.getElementById("listeLocalites"),
  boutonRestaurants: document.getElementById("boutonRestaurants"),
  listeRestaurants: document.getElementById("listeRestaurants"),
  boutonToutAfficher: document.getElementById("boutonToutAfficher"),
  boutonChanger: document.getElementById("boutonChanger"),
  resumeSelection: document.getElementById("resumeSelection"),
  voirSelection: document.getElementById("voirSelection"),
  voirCommande: document.getElementById("voirCommande"),
  compteur: document.getElementById("compteur"),
  resultats: document.getElementById("resultats"),
  modal: document.getElementById("modal"),
  toastCopie: document.getElementById("toastCopie"),
  fermerModal: document.getElementById("fermerModal"),
  contenuModal: document.getElementById("contenuModal")
};

function nettoyerTexte(valeur) {
  return String(valeur ?? "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/œ/g, "oe")
    .replace(/æ/g, "ae")
    .toLowerCase()
    .trim();
}

function echapperHtml(valeur) {
  return String(valeur ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function valeurOuNonRenseignee(valeur) {
  const texte = String(valeur ?? "").trim();
  return texte || "Non renseigné";
}

function detecterSeparateur(texte) {
  let dansGuillemets = false;
  const compteurs = { ";": 0, ",": 0, "\t": 0 };
  for (let i = 0; i < Math.min(texte.length, 10000); i++) {
    const caractere = texte[i];
    if (caractere === '"') {
      if (dansGuillemets && texte[i + 1] === '"') {
        i++;
      } else {
        dansGuillemets = !dansGuillemets;
      }
    } else if (!dansGuillemets && caractere === "\n") {
      break;
    } else if (!dansGuillemets && Object.prototype.hasOwnProperty.call(compteurs, caractere)) {
      compteurs[caractere]++;
    }
  }
  return Object.entries(compteurs).sort((a, b) => b[1] - a[1])[0][0];
}

function analyserCsv(texte) {
  const separateur = detecterSeparateur(texte);
  const lignes = [];
  let ligne = [];
  let champ = "";
  let dansGuillemets = false;

  for (let i = 0; i < texte.length; i++) {
    const caractere = texte[i];

    if (dansGuillemets) {
      if (caractere === '"') {
        if (texte[i + 1] === '"') {
          champ += '"';
          i++;
        } else {
          dansGuillemets = false;
        }
      } else {
        champ += caractere;
      }
    } else if (caractere === '"') {
      dansGuillemets = true;
    } else if (caractere === separateur) {
      ligne.push(champ);
      champ = "";
    } else if (caractere === "\n") {
      ligne.push(champ.replace(/\r$/, ""));
      if (ligne.some(cellule => cellule.trim() !== "")) lignes.push(ligne);
      ligne = [];
      champ = "";
    } else {
      champ += caractere;
    }
  }

  ligne.push(champ.replace(/\r$/, ""));
  if (ligne.some(cellule => cellule.trim() !== "")) lignes.push(ligne);

  if (lignes.length < 2) throw new Error("Le fichier ne contient pas de données exploitables.");

  const entetes = lignes[0].map((entete, index) => index === 0 ? entete.replace(/^\uFEFF/, "").trim() : entete.trim());
  return lignes.slice(1).map(valeurs => {
    const objet = {};
    entetes.forEach((entete, index) => {
      objet[entete] = String(valeurs[index] ?? "").trim();
    });
    return objet;
  });
}

function indexerColonnes(objet) {
  const index = {};
  Object.keys(objet).forEach(cle => {
    index[nettoyerTexte(cle).replace(/[^a-z0-9]/g, "")] = objet[cle];
  });
  return index;
}

function lireColonne(index, ...noms) {
  for (const nom of noms) {
    const cle = nettoyerTexte(nom).replace(/[^a-z0-9]/g, "");
    if (Object.prototype.hasOwnProperty.call(index, cle)) return String(index[cle] ?? "").trim();
  }
  return "";
}

function convertirLigne(ligne, indexOriginal) {
  const c = indexerColonnes(ligne);
  return {
    indexOriginal,
    restaurant: lireColonne(c, "Nom officiel du restaurant", "Restaurant", "Nom du restaurant"),
    rue: lireColonne(c, "Rue", "Adresse"),
    npa: lireColonne(c, "NPA", "Code postal"),
    localite: lireColonne(c, "Localité", "Localite", "Ville"),
    telephone: lireColonne(c, "Téléphone", "Telephone"),
    email: lireColonne(c, "E-mail", "Email", "Courriel"),
    site: lireColonne(c, "Site Internet", "Site web", "Site"),
    lienMenu: lireColonne(c, "Lien direct carte/menu", "Lien carte menu", "Menu"),
    typeCuisine: lireColonne(c, "Type de cuisine", "Cuisine"),
    terrasse: lireColonne(c, "Terrasse"),
    horaires: lireColonne(c, "Horaires", "Horaire"),
    fermeture: lireColonne(c, "Jours de fermeture", "Jour de fermeture", "Fermeture"),
    dateMenu: lireColonne(c, "Date du menu"),
    dateIntroduction: lireColonne(c, "Date d'introduction", "Date introduction"),
    dateRecuperation: lireColonne(c, "Date de récupération Web", "Date de recuperation Web", "Date de récupération"),
    fourniPar: lireColonne(c, "Fourni par", "Source"),
    categorie: lireColonne(c, "Catégorie", "Categorie"),
    plat: lireColonne(c, "Nom du plat", "Plat"),
    description: lireColonne(c, "Description"),
    prix: lireColonne(c, "Prix"),
    identifiant: [lireColonne(c, "Nom officiel du restaurant", "Restaurant", "Nom du restaurant"), lireColonne(c, "Nom du plat", "Plat"), lireColonne(c, "Catégorie", "Categorie"), lireColonne(c, "Prix"), indexOriginal].map(nettoyerTexte).join("|")
  };
}

function verifierColonnes(plats) {
  if (!plats.length) throw new Error("Aucune ligne de données n'a été trouvée.");
  const premierValide = plats.find(p => p.restaurant || p.plat) || plats[0];
  const manquantes = [];
  if (!premierValide.restaurant) manquantes.push("Nom officiel du restaurant");
  if (!premierValide.plat) manquantes.push("Nom du plat");
  if (manquantes.length) {
    throw new Error("Colonnes obligatoires absentes ou non reconnues : " + manquantes.join(", ") + ".");
  }
}

async function lireFichier(file) {
  const tampon = await file.arrayBuffer();
  try {
    return new TextDecoder("utf-8", { fatal: true }).decode(tampon);
  } catch (erreur) {
    return new TextDecoder("windows-1252").decode(tampon);
  }
}

function chargerTexteCsv(texte, nomFichier, memoriser = false) {
  const lignes = analyserCsv(texte);
  const plats = lignes
    .map((ligne, index) => convertirLigne(ligne, index))
    .filter(p => p.restaurant || p.plat);

  verifierColonnes(plats);
  etat.plats = plats;
  etat.fichier = nomFichier || "Restaurants.csv";
  etat.categoriesSelectionnees.clear();
  etat.localitesSelectionnees.clear();
  etat.restaurantsSelectionnes.clear();

  if (memoriser) {
    try {
      localStorage.setItem(CLE_MEMOIRE, JSON.stringify({ nom: etat.fichier, texte }));
    } catch (erreurMemoire) {
      console.warn("Mémorisation impossible", erreurMemoire);
    }
  }

  elements.etatChargement.className = "etat succes";
  elements.etatChargement.textContent = memoriser ? "Fichier chargé et mémorisé sur cet appareil." : "Fichier mémorisé rechargé automatiquement.";
  initialiserApplication();
}

async function chargerFichier(file) {
  if (!file) return;
  elements.etatChargement.className = "etat";
  elements.etatChargement.textContent = "Lecture du fichier en cours…";

  try {
    const texte = await lireFichier(file);
    chargerTexteCsv(texte, file.name, true);
  } catch (erreur) {
    console.error(erreur);
    etat.plats = [];
    elements.application.classList.add("cache");
    elements.etatChargement.className = "etat erreur";
    elements.etatChargement.textContent = "Impossible de lire ce fichier. " + (erreur.message || "Vérifiez son format CSV.");
  }
}

function valeursUniques(cle) {
  return [...new Set(etat.plats.map(p => p[cle]).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, "fr", { sensitivity: "base" }));
}

function texteBoutonMultiple(selection, total, singulier, pluriel) {
  if (selection.size === 0) return "Tous les " + pluriel;
  if (selection.size === 1) return [...selection][0];
  return selection.size + " " + pluriel + " sélectionnés";
}

function remplirListeMultiple(conteneur, valeurs, selection, bouton, singulier, pluriel, apresModification = null) {
  conteneur.innerHTML = "";
  valeurs.forEach(valeur => {
    const label = document.createElement("label");
    label.className = "multi-option";
    const caseACocher = document.createElement("input");
    caseACocher.type = "checkbox";
    caseACocher.value = valeur;
    caseACocher.checked = selection.has(valeur);
    const texte = document.createElement("span");
    texte.textContent = valeur;
    label.append(caseACocher, texte);
    conteneur.appendChild(label);

    caseACocher.addEventListener("change", () => {
      if (caseACocher.checked) selection.add(valeur);
      else selection.delete(valeur);
      bouton.textContent = texteBoutonMultiple(selection, valeurs.length, singulier, pluriel);
      bouton.classList.toggle("actif", selection.size > 0);
      if (typeof apresModification === "function") apresModification();
      afficherResultats();
    });
  });
  bouton.textContent = texteBoutonMultiple(selection, valeurs.length, singulier, pluriel);
  bouton.classList.toggle("actif", selection.size > 0);
}

function restaurantsDisponibles() {
  const lignes = etat.plats.filter(plat => {
    if (etat.categoriesSelectionnees.size && !etat.categoriesSelectionnees.has(plat.categorie)) return false;
    if (etat.localitesSelectionnees.size && !etat.localitesSelectionnees.has(plat.localite)) return false;
    return true;
  });
  return [...new Set(lignes.map(plat => plat.restaurant).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b, "fr", { sensitivity: "base" }));
}

function actualiserFiltreRestaurants() {
  const disponibles = restaurantsDisponibles();
  const ensembleDisponible = new Set(disponibles);
  [...etat.restaurantsSelectionnes].forEach(restaurant => {
    if (!ensembleDisponible.has(restaurant)) etat.restaurantsSelectionnes.delete(restaurant);
  });
  remplirListeMultiple(
    elements.listeRestaurants,
    disponibles,
    etat.restaurantsSelectionnes,
    elements.boutonRestaurants,
    "restaurant",
    "restaurants"
  );
}

function basculerListe(bouton, liste) {
  const ouvrir = liste.classList.contains("cache");
  document.querySelectorAll(".multi-liste").forEach(element => element.classList.add("cache"));
  document.querySelectorAll(".multi-bouton").forEach(element => element.setAttribute("aria-expanded", "false"));
  if (ouvrir) {
    liste.classList.remove("cache");
    bouton.setAttribute("aria-expanded", "true");
  }
}

function initialiserApplication() {
  elements.nomFichier.textContent = etat.fichier;
  elements.nombrePlats.textContent = etat.plats.length;
  elements.nombreRestaurants.textContent = new Set(etat.plats.map(p => p.restaurant).filter(Boolean)).size;
  remplirListeMultiple(
    elements.listeCategories,
    valeursUniques("categorie"),
    etat.categoriesSelectionnees,
    elements.boutonCategories,
    "catégorie",
    "catégories",
    actualiserFiltreRestaurants
  );
  remplirListeMultiple(
    elements.listeLocalites,
    valeursUniques("localite"),
    etat.localitesSelectionnees,
    elements.boutonLocalites,
    "localité",
    "localités",
    actualiserFiltreRestaurants
  );
  actualiserFiltreRestaurants();
  elements.recherche.value = "";
  elements.effacerRecherche.classList.add("cache");
  elements.zoneChargement.classList.add("cache");
  elements.application.classList.remove("cache");
  restaurerSelection();
  actualiserResumeSelection();
  afficherResultats();
  elements.application.scrollIntoView({ behavior: "smooth", block: "start" });
}

function fermerSuggestions() {
  elements.suggestions.classList.add("cache");
  elements.suggestions.innerHTML = "";
  elements.recherche.setAttribute("aria-expanded", "false");
  etat.suggestionActive = -1;
}

function motsSuggeres() {
  const saisie = nettoyerTexte(elements.recherche.value).trim();
  if (saisie.length < 3 || saisie.includes(" ")) return [];

  const mots = new Map();
  etat.plats.forEach(plat => {
    if (etat.categoriesSelectionnees.size && !etat.categoriesSelectionnees.has(plat.categorie)) return;
    if (etat.localitesSelectionnees.size && !etat.localitesSelectionnees.has(plat.localite)) return;
    if (etat.restaurantsSelectionnes.size && !etat.restaurantsSelectionnes.has(plat.restaurant)) return;

    const nomOriginal = String(plat.plat || "").trim();
    const morceaux = nomOriginal.match(/[A-Za-zÀ-ÖØ-öø-ÿŒœÆæ'-]+/g) || [];
    morceaux.forEach(motOriginal => {
      const motAffiche = motOriginal.replace(/^['’-]+|['’-]+$/g, "");
      const motNettoye = nettoyerTexte(motAffiche);
      if (motNettoye.length < 3 || !motNettoye.startsWith(saisie)) return;
      if (!mots.has(motNettoye)) mots.set(motNettoye, motAffiche);
    });
  });

  return Array.from(mots.values()).sort((a, b) => a.localeCompare(b, "fr", { sensitivity: "base" }));
}

function afficherSuggestions() {
  const saisie = nettoyerTexte(elements.recherche.value).trim();
  if (saisie.length < 3 || saisie.includes(" ")) {
    fermerSuggestions();
    return;
  }

  const suggestions = motsSuggeres();
  elements.suggestions.innerHTML = "";
  etat.suggestionActive = -1;

  if (!suggestions.length) {
    elements.suggestions.innerHTML = '<div class="suggestions-entete">Aucun mot correspondant</div>';
    elements.suggestions.classList.remove("cache");
    elements.recherche.setAttribute("aria-expanded", "true");
    return;
  }

  const entete = document.createElement("div");
  entete.className = "suggestions-entete";
  entete.textContent = suggestions.length + " mot" + (suggestions.length > 1 ? "s" : "") + " proposé" + (suggestions.length > 1 ? "s" : "");
  elements.suggestions.appendChild(entete);

  suggestions.forEach((mot, index) => {
    const bouton = document.createElement("button");
    bouton.type = "button";
    bouton.className = "suggestion";
    bouton.setAttribute("role", "option");
    bouton.dataset.index = String(index);
    bouton.textContent = mot;
    bouton.addEventListener("click", () => selectionnerSuggestion(mot));
    elements.suggestions.appendChild(bouton);
  });

  elements.suggestions.classList.remove("cache");
  elements.recherche.setAttribute("aria-expanded", "true");
}

function selectionnerSuggestion(mot) {
  elements.recherche.value = mot;
  elements.effacerRecherche.classList.remove("cache");
  fermerSuggestions();
  afficherResultats();
  elements.recherche.focus();
}

function gererClavierSuggestions(evenement) {
  if (elements.suggestions.classList.contains("cache")) return;
  const boutons = Array.from(elements.suggestions.querySelectorAll(".suggestion"));
  if (!boutons.length) return;

  if (evenement.key === "ArrowDown") {
    evenement.preventDefault();
    etat.suggestionActive = (etat.suggestionActive + 1) % boutons.length;
  } else if (evenement.key === "ArrowUp") {
    evenement.preventDefault();
    etat.suggestionActive = (etat.suggestionActive - 1 + boutons.length) % boutons.length;
  } else if (evenement.key === "Enter" && etat.suggestionActive >= 0) {
    evenement.preventDefault();
    boutons[etat.suggestionActive].click();
    return;
  } else if (evenement.key === "Escape") {
    fermerSuggestions();
    return;
  } else {
    return;
  }

  boutons.forEach((bouton, index) => bouton.classList.toggle("active", index === etat.suggestionActive));
  boutons[etat.suggestionActive].scrollIntoView({ block: "nearest" });
}

function obtenirResultatsFiltres() {
  const mots = nettoyerTexte(elements.recherche.value).split(/\s+/).filter(Boolean);
  return etat.plats.filter(plat => {
    if (etat.categoriesSelectionnees.size && !etat.categoriesSelectionnees.has(plat.categorie)) return false;
    if (etat.localitesSelectionnees.size && !etat.localitesSelectionnees.has(plat.localite)) return false;
    if (etat.restaurantsSelectionnes.size && !etat.restaurantsSelectionnes.has(plat.restaurant)) return false;

    const nomDuPlat = nettoyerTexte(plat.plat);
    return mots.every(mot => nomDuPlat.includes(mot));
  });
}

function formaterPrix(prix) {
  const valeur = String(prix ?? "").trim();
  if (!valeur) return "Prix non renseigné";
  return /chf/i.test(valeur) ? valeur : valeur + " CHF";
}

function platEstSelectionne(plat) {

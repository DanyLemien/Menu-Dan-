function platsSelectionnes() {
  return etat.plats.filter(plat => etat.selectionPlats.has(plat.identifiant));
}

function memoriserSelection() {
  try {
    localStorage.setItem(CLE_SELECTION, JSON.stringify({
      restaurant: etat.restaurantSelection,
      identifiants: [...etat.selectionPlats],
      quantites: etat.quantitesSelection,
      prixUnitaires: etat.prixUnitairesSaisis
    }));
  } catch (erreur) {
    console.warn("Mémorisation de la sélection impossible", erreur);
  }
}

function restaurerSelection() {
  try {
    const brut = localStorage.getItem(CLE_SELECTION);
    if (!brut) return;
    const sauvegarde = JSON.parse(brut);
    const idsDisponibles = new Set(etat.plats.map(p => p.identifiant));
    etat.selectionPlats = new Set((sauvegarde.identifiants || []).filter(id => idsDisponibles.has(id)));
    etat.quantitesSelection = {};
    etat.prixUnitairesSaisis = {};
    etat.selectionPlats.forEach(id => { etat.quantitesSelection[id] = Math.max(1, Number((sauvegarde.quantites || {})[id] || 1)); });
    Object.entries(sauvegarde.prixUnitaires || {}).forEach(([id, valeur]) => {
      if (idsDisponibles.has(id)) {
        const n = Number(valeur);
        if (Number.isFinite(n) && n > 0 && n <= 1000) etat.prixUnitairesSaisis[id] = n;
      }
    });
    const selection = platsSelectionnes();
    etat.restaurantSelection = selection.length ? selection[0].restaurant : "";
    memoriserSelection();
  } catch (erreur) {
    console.warn("Sélection mémorisée illisible", erreur);
    etat.selectionPlats.clear();
    etat.quantitesSelection = {};
    etat.prixUnitairesSaisis = {};
    etat.restaurantSelection = "";
  }
}

function actualiserResumeSelection() {
  const selection = platsSelectionnes();
  const nombre = selection.reduce((total, plat) => total + Number(etat.quantitesSelection[plat.identifiant] || 1), 0);
  elements.resumeSelection.textContent = nombre
    ? `${etat.restaurantSelection} · ${nombre} article${nombre > 1 ? "s" : ""} sélectionné${nombre > 1 ? "s" : ""}`
    : "Aucun plat sélectionné";
  elements.voirSelection.disabled = nombre === 0;
  elements.voirCommande.disabled = nombre === 0;
}

function viderSelection(sansConfirmation = false) {
  if (!sansConfirmation && etat.selectionPlats.size && !window.confirm(`Supprimer les ${etat.selectionPlats.size} plats sélectionnés ?`)) return;
  etat.selectionPlats.clear();
  etat.quantitesSelection = {};
  etat.prixUnitairesSaisis = {};
  etat.restaurantSelection = "";
  memoriserSelection();
  actualiserResumeSelection();
  afficherResultats();
}

function verifierRestaurantPourAjout(plat) {
  if (etat.restaurantSelection && etat.restaurantSelection !== plat.restaurant) {
    const remplacer = window.confirm(`La sélection actuelle concerne « ${etat.restaurantSelection} ».\n\nEffacer cette sélection et commencer une commande pour « ${plat.restaurant} » ?`);
    if (!remplacer) return false;
    etat.selectionPlats.clear();
    etat.quantitesSelection = {};
    etat.prixUnitairesSaisis = {};
  }
  etat.restaurantSelection = plat.restaurant;
  return true;
}

function modifierQuantite(index, variation) {
  const plat = etat.plats[index];
  if (!plat) return;
  const actuelle = Number(etat.quantitesSelection[plat.identifiant] || 0);
  if (variation > 0 && actuelle === 0 && !verifierRestaurantPourAjout(plat)) return;
  const nouvelle = Math.max(0, actuelle + variation);
  if (nouvelle === 0) {
    delete etat.quantitesSelection[plat.identifiant];
    delete etat.prixUnitairesSaisis[plat.identifiant];
    etat.selectionPlats.delete(plat.identifiant);
    if (!etat.selectionPlats.size) etat.restaurantSelection = "";
  } else {
    etat.quantitesSelection[plat.identifiant] = nouvelle;
    etat.selectionPlats.add(plat.identifiant);
  }
  memoriserSelection();
  actualiserResumeSelection();
  afficherResultats();
}

function basculerSelection(index) {
  const plat = etat.plats[index];
  if (!plat) return;
  modifierQuantite(index, etat.selectionPlats.has(plat.identifiant) ? -Number(etat.quantitesSelection[plat.identifiant] || 1) : 1);
}

function ordreCategorie(categorie) {
  const c = nettoyerTexte(categorie);
  const regles = [
    [0, ["aperitif", "amuse", "mise en bouche"]],
    [10, ["entree", "salade", "soupe", "potage"]],
    [20, ["poisson", "fruit de mer", "crustace"]],
    [30, ["plat", "viande", "volaille", "pates", "pizza", "vegetar"]],
    [40, ["fromage"]],
    [50, ["dessert", "glace", "sorbet"]],
    [60, ["vin", "champagne", "boisson", "biere", "digestif", "cafe"]]
  ];
  for (const [rang, mots] of regles) if (mots.some(mot => c.includes(mot))) return rang;
  return 35;
}

function analyserPrix(prix) {
  const original = String(prix ?? "").trim();
  if (!original) return { valide:false, valeur:null, raison:"Prix non renseigné", original:"" };
  const nombres = original.match(/\d+(?:[.,]\d{1,2})?/g) || [];
  if (nombres.length !== 1) {
    return { valide:false, valeur:null, raison:nombres.length > 1 ? "Plusieurs prix possibles" : "Prix illisible", original };
  }
  const valeur = Number.parseFloat(nombres[0].replace(",", "."));
  if (!Number.isFinite(valeur) || valeur <= 0 || valeur > 1000) {
    return { valide:false, valeur:null, raison:"Montant incohérent", original };
  }
  return { valide:true, valeur, raison:"", original };
}

function prixNumerique(prix) {
  const controle = analyserPrix(prix);
  return controle.valide ? controle.valeur : null;
}

function obtenirPrixUnitaire(plat) {
  const saisi = Number(etat.prixUnitairesSaisis[plat.identifiant]);
  if (Number.isFinite(saisi) && saisi > 0 && saisi <= 1000) {
    return { valide:true, valeur:saisi, raison:"Prix saisi manuellement", original:String(saisi), manuel:true };
  }
  return analyserPrix(plat.prix);
}

function enregistrerPrixUnitaire(id, valeurBrute) {
  const texte = String(valeurBrute ?? "").trim().replace(",", ".");
  const valeur = Number.parseFloat(texte);
  if (!Number.isFinite(valeur) || valeur <= 0 || valeur > 1000) {
    delete etat.prixUnitairesSaisis[id];
    memoriserSelection();
    ouvrirCommande();
    return;
  }
  etat.prixUnitairesSaisis[id] = Math.round(valeur * 100) / 100;
  memoriserSelection();
  ouvrirCommande();
}


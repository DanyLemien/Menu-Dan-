          <div><div class="selection-nom">${echapperHtml(p.plat)}</div><div class="selection-meta">${echapperHtml(valeurOuNonRenseignee(p.categorie))} · ${echapperHtml(formaterPrix(p.prix))}</div><div class="selection-item-quantite"><strong>Quantité :</strong><button type="button" class="quantite-bouton" data-diminuer-id="${echapperHtml(p.identifiant)}">−</button><span class="quantite-valeur">${Number(etat.quantitesSelection[p.identifiant] || 1)}</span><button type="button" class="quantite-bouton" data-augmenter-id="${echapperHtml(p.identifiant)}">+</button></div></div>

<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#12733d">
<title>Restaurants de Neuchâtel — version 4.5</title>
<style>
:root{
  --fond:#f3f6f4;
  --carte:#ffffff;
  --texte:#18211c;
  --secondaire:#5d6861;
  --primaire:#12733d;
  --primaire-fonce:#0b542c;
  --primaire-clair:#e7f4ec;
  --accent:#d5232f;
  --accent-clair:#fff0f1;
  --danger:#b51f2a;
  --bordure:#d7e1da;
  --ombre:0 8px 24px rgba(18,115,61,.10);
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  padding:env(safe-area-inset-top) 0 env(safe-area-inset-bottom);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;
  background:var(--fond);
  color:var(--texte);
  line-height:1.4;
}
button,input,select{font:inherit}
button{touch-action:manipulation}
a{color:var(--primaire);overflow-wrap:anywhere}
.page{width:min(920px,100%);margin:0 auto;padding:14px}
.entete{
  background:linear-gradient(115deg,#0b6b36 0%,#15924f 37%,#ffffff 37%,#ffffff 64%,#d5232f 64%,#b91824 100%);
  color:#162019;
  border-radius:18px;
  padding:20px;
  box-shadow:var(--ombre);
  margin-bottom:14px;
}
.entete h1{font-size:clamp(25px,6vw,36px);line-height:1.08;margin:0 0 8px;text-shadow:0 1px 0 rgba(255,255,255,.65)}
.entete p{margin:0;color:#26362c;font-weight:650;max-width:720px}
.panneau{background:var(--carte);border-radius:16px;padding:16px;box-shadow:var(--ombre);margin-bottom:14px}
.panneau h2{font-size:20px;margin:0 0 10px}
.explication{color:var(--secondaire);margin:0 0 14px}
.fichier-label,.bouton-principal,.bouton-secondaire{
  display:flex;
  align-items:center;
  justify-content:center;
  width:100%;
  min-height:50px;
  border-radius:12px;
  padding:12px 15px;
  font-weight:750;
  cursor:pointer;
  text-align:center;
}
.fichier-label,.bouton-principal{background:var(--primaire);color:#fff;border:0}
.fichier-label input{position:absolute;left:-9999px}
.bouton-secondaire{background:#fff;color:var(--primaire);border:2px solid var(--primaire)}
.etat{margin-top:12px;padding:11px 12px;border-radius:10px;background:#f4f7f9;color:var(--secondaire)}
.etat.erreur{background:#fff0f0;color:var(--danger);font-weight:650}
.etat.succes{background:#edf8f0;color:#236334}
.cache{display:none!important}
.barre-fichier{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center}
.nom-fichier{font-size:14px;color:var(--secondaire);overflow-wrap:anywhere}
.changer{border:1px solid var(--bordure);background:#fff;color:var(--primaire);border-radius:10px;padding:9px 12px;font-weight:700;cursor:pointer}
.stats{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:12px}
.stat{background:var(--primaire-clair);border-radius:12px;padding:11px;text-align:center}
.stat strong{display:block;font-size:24px;color:var(--primaire)}
.stat span{font-size:13px;color:var(--secondaire)}
.recherche-grid{display:grid;gap:10px}
.recherche-zone{position:relative}
.recherche-saisie{position:relative}
.recherche-saisie .champ{padding-right:54px}
.effacer-recherche{position:absolute;right:10px;top:50%;transform:translateY(-50%);width:36px;height:36px;border:0;border-radius:50%;background:#e7eee9;color:#0b5d35;font-size:25px;font-weight:800;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer}
.effacer-recherche.cache{display:none}
.effacer-recherche:active{background:#d2e2d7}
.champ,.selecteur{
  width:100%;
  min-height:50px;
  border:2px solid var(--bordure);
  border-radius:12px;
  padding:11px 13px;
  background:#fff;
  color:var(--texte);
}
.champ{font-size:19px}
.champ:focus,.selecteur:focus{outline:3px solid rgba(23,50,77,.16);border-color:var(--primaire)}

.suggestions{
  position:absolute;
  left:0;
  right:0;
  top:calc(100% + 6px);
  z-index:50;
  max-height:330px;
  overflow:auto;
  background:#fff;
  border:2px solid var(--primaire);
  border-radius:12px;
  box-shadow:0 14px 32px rgba(0,0,0,.18);
}
.suggestions-entete{padding:9px 12px;background:var(--primaire-clair);color:var(--primaire-fonce);font-size:13px;font-weight:800;border-bottom:1px solid var(--bordure);position:sticky;top:0}
.suggestion{display:block;width:100%;border:0;border-bottom:1px solid #edf0ee;background:#fff;color:var(--texte);padding:11px 13px;text-align:left;cursor:pointer;font-weight:700;line-height:1.25}
.suggestion:last-child{border-bottom:0}
.suggestion:active,.suggestion.active{background:var(--primaire-clair);color:var(--primaire-fonce)}
.suggestion small{display:block;margin-top:3px;color:var(--secondaire);font-weight:600}

.filtres{display:grid;grid-template-columns:1fr;gap:10px}
.multi-filtre{position:relative}
.multi-bouton{width:100%;min-height:50px;border:2px solid var(--bordure);border-radius:12px;padding:11px 13px;background:#fff;color:var(--texte);text-align:left;font-weight:700;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:8px}
.multi-bouton::after{content:"▾";color:var(--primaire);font-size:18px}
.multi-bouton.actif{border-color:var(--primaire);background:var(--primaire-clair)}
.multi-liste{margin-top:7px;border:1px solid var(--bordure);border-radius:12px;background:#fff;max-height:260px;overflow:auto;padding:7px;box-shadow:0 8px 20px rgba(0,0,0,.10)}
.multi-option{display:flex;align-items:flex-start;gap:10px;padding:10px 8px;border-radius:9px;cursor:pointer}
.multi-option:active{background:var(--primaire-clair)}
.multi-option input{width:22px;height:22px;accent-color:var(--primaire);flex:0 0 auto;margin-top:0}
.multi-option span{font-weight:650;line-height:1.25}
.memoire-info{margin-top:10px;padding:10px 12px;border-radius:10px;background:linear-gradient(90deg,var(--primaire-clair),#fff,var(--accent-clair));font-size:14px;color:var(--secondaire)}
.compteur{font-weight:800;margin:14px 2px 10px;color:var(--primaire)}
.resultats{display:grid;gap:12px}
.carte-plat{
  width:100%;
  border:1px solid var(--bordure);
  border-radius:16px;
  background:var(--carte);
  padding:0;
  text-align:left;
  color:inherit;
  box-shadow:0 4px 14px rgba(18,115,61,.08);border-left:5px solid var(--primaire);
  cursor:pointer;
  overflow:hidden;
}
.carte-plat:active{transform:scale(.995)}
.carte-tete{padding:12px 14px;background:linear-gradient(90deg,var(--primaire-clair),#fff);border-bottom:1px solid var(--bordure)}
.resto{font-weight:850;color:var(--primaire);font-size:15px}
.localite{font-size:14px;color:var(--secondaire);margin-top:2px}
.carte-corps{padding:14px}
.plat{font-size:21px;line-height:1.16;margin:0 0 5px}
.categorie{display:inline-block;font-size:13px;font-weight:800;color:#fff;background:var(--accent);border-radius:999px;padding:4px 9px;margin-bottom:9px}
.description{color:#35414b;margin-bottom:10px}
.prix{font-size:20px;font-weight:900;color:var(--primaire)}
.infos-rapides{display:grid;grid-template-columns:1fr;gap:7px;margin-top:12px;padding-top:11px;border-top:1px solid var(--bordure);font-size:14px}
.info-rapide strong{color:var(--texte)}
.indication{font-size:13px;color:var(--secondaire);margin-top:10px;font-weight:650}
.vide{text-align:center;background:#fff;border-radius:14px;padding:28px 16px;color:var(--secondaire)}
.modal{
  position:fixed;
  inset:0;
  z-index:1000;
  background:rgba(10,22,33,.58);
  display:flex;
  align-items:flex-end;
  justify-content:center;
  padding-top:24px;
}
.modal-contenu{
  width:min(760px,100%);
  max-height:94vh;
  overflow:auto;
  background:var(--fond);
  border-radius:22px 22px 0 0;
  box-shadow:0 -10px 40px rgba(0,0,0,.25);
  padding:14px 14px calc(16px + env(safe-area-inset-bottom));
}
.modal-barre{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:12px}
.modal-barre h2{margin:3px 0 0;font-size:24px;line-height:1.15}
.fermer{flex:0 0 auto;width:44px;height:44px;border-radius:50%;border:0;background:#fff;font-size:25px;line-height:1;cursor:pointer;box-shadow:0 2px 10px rgba(0,0,0,.12)}
.bloc{background:#fff;border-radius:15px;padding:14px;margin-bottom:12px;box-shadow:0 3px 12px rgba(23,50,77,.06)}
.bloc h3{margin:0 0 10px;color:var(--primaire);font-size:18px}
.fiche-grid{display:grid;grid-template-columns:1fr;gap:0}
.ligne-fiche{padding:9px 0;border-bottom:1px solid #edf0f2}
.ligne-fiche:last-child{border-bottom:0}
.libelle{display:block;font-size:12px;text-transform:uppercase;letter-spacing:.04em;color:var(--secondaire);font-weight:800;margin-bottom:2px}
.valeur{font-weight:600;white-space:pre-line;overflow-wrap:anywhere}
.alerte-fermeture{background:linear-gradient(90deg,var(--accent-clair),#fff);border-left:5px solid var(--accent)}
.plat-selectionne{background:linear-gradient(135deg,var(--primaire-clair),#fff);border:1px solid #b8d8c5}
.actions{display:grid;grid-template-columns:1fr;gap:9px;margin-top:10px}
.action-lien{display:flex;align-items:center;justify-content:center;min-height:46px;border-radius:11px;background:var(--primaire);color:#fff;text-decoration:none;font-weight:800;padding:10px;text-align:center}
.action-lien.secondaire{background:#fff;color:var(--primaire);border:2px solid var(--primaire)}
.action-lien.rouge{background:#fff;color:var(--accent);border:2px solid var(--accent)}
.provenance{margin-top:12px;padding:12px 14px;border-radius:12px;background:linear-gradient(90deg,var(--primaire-clair),#fff,var(--accent-clair));border:1px solid var(--bordure)}
.provenance .libelle{color:var(--primaire-fonce)}
@media(min-width:620px){
  .filtres{grid-template-columns:repeat(2,1fr)}
  .resultats{grid-template-columns:repeat(2,minmax(0,1fr))}
  .infos-rapides{grid-template-columns:1fr 1fr}
  .fiche-grid{grid-template-columns:repeat(2,minmax(0,1fr));column-gap:22px}
  .actions{grid-template-columns:repeat(2,1fr)}
  .modal{align-items:center;padding:24px}
  .modal-contenu{border-radius:22px;max-height:90vh}
}

.toast-copie{position:fixed;left:50%;bottom:24px;transform:translateX(-50%) translateY(20px);background:#0b5d35;color:#fff;padding:12px 18px;border-radius:12px;font-weight:800;box-shadow:0 8px 30px rgba(0,0,0,.25);opacity:0;pointer-events:none;transition:.2s;z-index:10000;max-width:88vw;text-align:center}
.toast-copie.visible{opacity:1;transform:translateX(-50%) translateY(0)}
.note-liens{margin:12px 0 0;padding:12px;border:1px solid #d8b3b7;border-radius:12px;background:linear-gradient(90deg,#eef7f1,#fff,#faeeee);font-size:14px;line-height:1.4}
.action-lien{cursor:pointer}

.version-app{margin-top:10px;font-size:13px;font-weight:800;color:#26362c}
.recherche-ligne{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:9px;align-items:start}
.bouton-effacer-filtres{min-height:44px;border:0;border-radius:10px;padding:9px 12px;background:var(--danger);color:#fff;font-weight:800;cursor:pointer;white-space:nowrap}
.bouton-effacer-filtres:active{transform:scale(.98)}
.selection-barre{display:flex;flex-wrap:wrap;gap:9px;align-items:center;justify-content:space-between;margin-bottom:12px;padding:11px 12px;border-radius:12px;background:linear-gradient(90deg,var(--primaire-clair),#fff);position:sticky;top:8px;z-index:120;box-shadow:0 6px 18px rgba(18,115,61,.14)}
.selection-resume{font-weight:800;color:var(--primaire-fonce)}
.selection-actions{display:flex;flex-wrap:wrap;gap:8px}
.bouton-selection,.bouton-commande{border:0;border-radius:10px;padding:10px 12px;font-weight:800;cursor:pointer}
.bouton-selection{background:var(--primaire);color:#fff}
.bouton-commande{background:#17324d;color:#fff}
.bouton-selection:disabled,.bouton-commande:disabled{opacity:.45;cursor:not-allowed}
.carte-actions{display:grid;grid-template-columns:1fr;gap:8px;margin-top:12px}
.bouton-ajouter-selection{min-height:43px;border:2px solid var(--primaire);border-radius:10px;background:#fff;color:var(--primaire);font-weight:850;cursor:pointer}
.bouton-ajouter-selection.selectionne{background:var(--primaire);color:#fff}
.selection-item{display:grid;grid-template-columns:auto minmax(0,1fr) auto;gap:10px;align-items:start;padding:11px 0;border-bottom:1px solid var(--bordure)}
.selection-item:last-child{border-bottom:0}
.selection-item input{width:21px;height:21px;accent-color:var(--primaire);margin-top:2px}
.selection-nom{font-weight:800}
.selection-meta{font-size:13px;color:var(--secondaire);margin-top:3px}
.bouton-retirer{border:1px solid var(--danger);border-radius:9px;background:#fff;color:var(--danger);padding:7px 9px;font-weight:800;cursor:pointer}
.actions-selection-bas{display:grid;gap:9px;margin-top:12px}
.bouton-danger{min-height:44px;border:0;border-radius:10px;background:var(--danger);color:#fff;font-weight:850;cursor:pointer}
.bouton-neutre{min-height:44px;border:2px solid var(--primaire);border-radius:10px;background:#fff;color:var(--primaire);font-weight:850;cursor:pointer}
.commande-feuille{background:#fff;border:1px solid var(--bordure);border-radius:14px;padding:16px}
.commande-restaurant{font-size:22px;font-weight:900;color:var(--primaire);margin-bottom:4px}
.commande-sous-titre{color:var(--secondaire);margin-bottom:14px}
.commande-groupe{margin-top:14px}
.commande-groupe h3{margin:0 0 7px;padding-bottom:5px;border-bottom:2px solid var(--primaire-clair);color:var(--primaire);font-size:17px}
.commande-ligne{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;padding:9px 0;border-bottom:1px solid #edf0ee}.commande-ligne:last-child{border-bottom:0}.commande-detail{display:block;margin-top:3px;color:var(--secondaire);font-size:14px;font-weight:700}.commande-montant{font-weight:900;white-space:nowrap;align-self:center}
.commande-ligne strong{font-size:16px}
.commande-prix{font-weight:800;white-space:nowrap}
.commande-total{margin-top:15px;padding-top:11px;border-top:2px solid var(--bordure);font-size:18px;font-weight:900;text-align:right}
.bouton-retour-fiche{width:100%;min-height:48px;margin-top:12px;border:2px solid var(--primaire);border-radius:11px;background:#fff;color:var(--primaire);font-weight:850;cursor:pointer}
.pied-page{padding:14px 4px 4px;text-align:center;color:var(--secondaire);font-size:13px;font-weight:700}
@media(min-width:620px){.carte-actions{grid-template-columns:1fr 1fr}.actions-selection-bas{grid-template-columns:1fr 1fr}}

.carte-tete{position:relative}
.carte-tete-infos{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:10px;align-items:start}
.carte-tete-meta{display:flex;flex-wrap:wrap;gap:8px 16px;margin-top:9px;font-size:13px;color:var(--texte)}
.carte-tete-meta strong{color:var(--texte)}
.bouton-fiche-entete{min-height:38px;border:2px solid var(--primaire);border-radius:9px;background:#fff;color:var(--primaire);font-weight:850;padding:7px 10px;cursor:pointer;white-space:nowrap}
.selection-plat-bas{display:flex;justify-content:flex-end;align-items:center;gap:9px;margin-top:14px;padding-top:12px;border-top:1px solid var(--bordure)}
.quantite-controle{display:flex;align-items:center;border:2px solid var(--primaire);border-radius:11px;overflow:hidden;background:#fff}
.quantite-bouton{width:42px;height:42px;border:0;background:#fff;color:var(--primaire);font-size:25px;font-weight:900;cursor:pointer}
.quantite-bouton:disabled{opacity:.35;cursor:not-allowed}
.quantite-valeur{min-width:38px;text-align:center;font-weight:900;color:var(--texte);font-size:17px}
.selection-libelle{font-weight:800;color:var(--primaire);font-size:14px}
.selection-item-quantite{display:flex;align-items:center;gap:7px;margin-top:7px}
.commande-quantite{display:inline-block;min-width:32px;font-weight:900;color:var(--primaire)}
@media(max-width:520px){.carte-tete-infos{grid-template-columns:1fr}.bouton-fiche-entete{width:100%}.selection-plat-bas{justify-content:space-between}}


/* Ajustements compacts de la version 4.2 */
.carte-tete{padding:10px 12px}
.carte-tete-infos{grid-template-columns:minmax(0,1fr) auto;gap:8px;align-items:center}
.resto{font-size:14px;line-height:1.2}
.localite{font-size:12px;margin-top:1px}
.carte-tete-meta{gap:4px 12px;margin-top:5px;font-size:12px;line-height:1.25}
.bouton-fiche-entete{min-height:32px;border-width:1.5px;border-radius:8px;padding:5px 9px;font-size:12px}
.carte-corps{position:relative;padding:11px 12px 12px;min-height:150px;padding-right:158px}
.plat{font-size:19px;line-height:1.14;margin:0 0 5px}
.categorie{font-size:12px;padding:3px 8px;margin-bottom:7px}
.description{font-size:14px;line-height:1.3;margin-bottom:7px}
.prix{font-size:19px;line-height:1.2;margin-top:4px}
.selection-plat-bas{position:absolute;right:12px;bottom:12px;display:block;margin:0;padding:0;border:0;text-align:center}
.selection-libelle{display:block;margin-bottom:3px;font-size:11px;line-height:1.1;color:var(--texte)}
.quantite-controle{border-width:1.5px;border-radius:9px}
.quantite-bouton{width:36px;height:34px;font-size:22px}
.quantite-valeur{min-width:32px;font-size:16px}
@media(max-width:520px){
  .carte-tete-infos{grid-template-columns:minmax(0,1fr) auto}
  .bouton-fiche-entete{width:auto}
  .carte-corps{padding-right:132px;min-height:150px}
  .selection-plat-bas{right:10px;bottom:10px}
  .quantite-bouton{width:34px}
  .quantite-valeur{min-width:28px}
}
@media(max-width:390px){
  .carte-tete-infos{grid-template-columns:1fr}
  .bouton-fiche-entete{justify-self:start;margin-top:3px}
  .carte-corps{padding-right:12px;padding-bottom:62px}
}



/* Version 4.6 : commandes sur une ligne et commandes supérieures compactes fixes */
.zone-controles-fixe{
  position:sticky;
  top:0;
  z-index:200;
  background:rgba(243,246,244,.97);
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  padding-top:4px;
  padding-bottom:4px;
  box-shadow:0 8px 16px rgba(18,115,61,.08);
}
.zone-controles-fixe .panneau{box-shadow:0 3px 10px rgba(18,115,61,.07)}
.panneau-fichier-compact{
  padding:7px 10px;
  margin-bottom:6px;
  border-radius:11px;
}
.panneau-fichier-compact .barre-fichier{grid-template-columns:minmax(0,1fr) auto;gap:7px}
.panneau-fichier-compact .barre-fichier strong{font-size:13px;line-height:1.05}
.panneau-fichier-compact .nom-fichier{font-size:10px;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.panneau-fichier-compact .changer{padding:5px 8px;border-radius:7px;font-size:11px}
.panneau-fichier-compact .stats{display:flex;gap:6px;margin-top:5px}
.panneau-fichier-compact .stat{flex:1;padding:3px 7px;border-radius:7px;display:flex;align-items:baseline;justify-content:center;gap:5px}
.panneau-fichier-compact .stat strong{display:inline;font-size:15px;line-height:1}
.panneau-fichier-compact .stat span{font-size:9px}
.panneau-recherche-compact{
  padding:7px 10px;
  margin-bottom:6px;
  border-radius:11px;
}
.panneau-recherche-compact .recherche-grid{gap:6px}
.panneau-recherche-compact .recherche-ligne{gap:6px}
.panneau-recherche-compact .champ{min-height:34px;padding:5px 37px 5px 9px;border-radius:8px;font-size:13px}
.panneau-recherche-compact .effacer-recherche{right:5px;width:25px;height:25px;font-size:18px}
.panneau-recherche-compact .bouton-effacer-filtres{min-height:34px;padding:5px 9px;border-radius:8px;font-size:11px}
.panneau-recherche-compact .filtres{gap:6px}
.panneau-recherche-compact .multi-bouton{min-height:34px;padding:5px 9px;border-radius:8px;font-size:11px;border-width:1.5px}
.panneau-recherche-compact .multi-bouton::after{font-size:13px}
.panneau-recherche-compact .multi-liste{max-height:210px;margin-top:4px;padding:4px;border-radius:8px}
.panneau-recherche-compact .multi-option{padding:6px 5px;gap:7px;font-size:12px}
.panneau-recherche-compact .multi-option input{width:17px;height:17px}
.zone-controles-fixe .selection-barre{

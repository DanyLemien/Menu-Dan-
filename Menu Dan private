      }
      const prixAffiche = controle.valeur.toFixed(2).replace(".", ",") + " CHF";
      const formule = `${quantite} × ${plat.plat} à ${prixAffiche} =`;
      const montantAffiche = montant.toFixed(2).replace(".", ",") + " CHF";
      return `<div class="commande-ligne"><div class="commande-formule">${echapperHtml(formule)}</div><div class="commande-montant">${echapperHtml(montantAffiche)}</div></div>`;
    }).join("")}
  </section>`).join("");
  const controleHtml = donnees.lignesAControler
    ? `<div class="commande-controle alerte">Contrôle des prix : ${donnees.lignesAControler} ligne${donnees.lignesAControler > 1 ? "s" : ""} à préciser. Aucun montant ambigu n’est additionné.</div>`
    : `<div class="commande-controle ok">Contrôle des prix : tous les montants sont cohérents et additionnés.</div>`;
  elements.contenuModal.innerHTML = `
    <section class="commande-feuille">
      <div class="commande-restaurant">${echapperHtml(etat.restaurantSelection)}</div>
